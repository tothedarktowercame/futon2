{:cohort/id :wm-outer-loop-41-v1
 :protocol/version 4
 :status :preregistered
 :registered-on "2026-07-21"
 :purpose "Post-repair validation cohort. Successor to :wm-outer-loop-40-v1 (target reached 2026-07-21). Runs with the deposited capability-zone posteriors (M-capability-zones; store 242 wm-hyperparameter-update hyperedges) and the CLI bootstrap-replay fix (futon2 662d159). Primary questions: (1) do production-shaped selections discriminate with fed gap-class credits (attempt-036's failure mode); (2) do grounded clicks validate the implemented machine repairs awaiting validation (oldest first, per runner :stop-line-validation)."
 :activation :separate-append-only-marker
 :population "Natural wall-clock or duree-triggered opportunities of the full War Machine loop"
 :stopping-rule
 {:unit :trigger-opportunity
  :target 10
  :rule "Count the first 10 distinct eligible trigger opportunities after activation, in order."
  :counts-as-attempt
  [:selected-and-dispatched
   :abstained
   :no-selection
   :agent-unavailable
   :substrate-unavailable
   :guardrail-refusal
   :dispatch-failed
   :build-failed
   :grounded-no-change
   :grounded-change]
  :excluded
  [:manual-test :replay :duplicate-opportunity :pre-activation]
  :replacement "None. Failed, unavailable, abstaining, and no-change opportunities remain in the denominator."}
 :allowed-triggers #{:wallclock-cron
                     :duree-click-on-demand
                     :duree-click-continuous}
 :checkpoint-order
 [:time-step :selection :construction :dispatch :build :adjudication :closed]
 :required-before-close
 #{:selection :construction :dispatch :build :adjudication}
 :checkpoint-contract
 {:cell-shape "Every checkpoint payload is either {:judgment ... :ground ...} or {:sorry {:kind keyword ...}}."
  :time-step [:opportunity-id :trigger :machine-state :agent-roster :code-state :semantic-epoch]
  :selection [:selected-mission :selected-action :ranked-candidates :selection-reasons]
  :construction [:mission :cascade :sorries :wiring :patterns :deposit]
  :dispatch [:agent :availability :job-id :prompt-ref]
  :build [:artifacts :generated-code :commits :patterns-used :inline-improvements :validation]
  :adjudication [:before :after :witness :build-match :dial]
  :closed [:outcome :grounded? :artifact-only? :duration-ms :resource-use]}
 :grounded-success
 {:outcome :grounded-change
  :requires [:independent-before-witness
             :independent-after-witness
             :resolved-adjudication
             :dial-moved]
  :artifact-only-counts? false}
 :machine-evolution
 {:allowed? true
  :rule "Normal machine development may continue during collection; it never permits dropping, replacing, or relabelling an opportunity."
  :per-attempt-provenance [:semantic-epoch :git-sha :git-dirty? :resolved-mode-flags :configuration-digest]
  :epoch-boundary "Increment semantic-epoch whenever ranking, policy support, dispatch, build, adjudication, or grounding semantics change."
  :analysis "Report attempts chronologically and stratified by semantic epoch; do not pool across an undocumented semantic boundary."}
 :analysis
 {:primary
  [:attempt-count
   :grounded-change-rate
   :grounded-no-change-rate
   :dispatch-rate
   :completion-rate]
  :secondary
  [:mission-selection-frequency
   :selection-reason-frequency
   :expected-versus-realized-calibration
   :agent-availability
   :elapsed-time
   :resource-use
   :patterns-used
   :inline-improvement-frequency
   :semantic-epoch-results
   :code-version-trajectory]
  :reporting "Report all 10 attempts and all typed sorries; do not analyse successes alone."}}
