   :statement "free_eq_empty_iff_surjective : Free s = ∅ ↔ Function.Surjective s ;; free_nonempty_iff_not_surjective : (Free s).Nonempty ↔ ¬ Function.Surjective s ;; where Free (s : N → N) := (Set.range s)ᶜ"
