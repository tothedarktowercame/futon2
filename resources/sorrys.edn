;; {:schema-version 1
;;  :sorrys [{:id            <:sorry/keyword unique id>
;;            :title         <one-line summary>
;;            :raised-at     <YYYY-MM-DD>
;;            :status        :open | :addressed | :foreclosed
;;            :rationale     <multi-line text explaining the gap>
;;            :kind          <optional; one of:>
;;                           :meta                  — apparatus surfaces this about itself
;;                           :prototyping-forward   — knowingly incomplete as v1 placeholder;
;;                                                    refinement IS the work, not debt to pay back
;;                                                    (per Joe 2026-05-18)
;;                           :technical-debt        — should have been done right; needs paying back
;;                           :decision-debt         — open decision deferred
;;                           :external-dependency   — gap depends on external work landing
